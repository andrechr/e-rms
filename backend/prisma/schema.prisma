generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Department {
    id        String     @id @default(uuid())
    name      String     @unique
    createdAt DateTime   @default(now())
    employees Employee[]
}

model Employee {
    id           String      @id @default(uuid())
    name         String
    email        String      @unique
    role         String?
    createdAt    DateTime    @default(now())
    departmentId String?
    department   Department? @relation(fields: [departmentId], references: [id])
}
